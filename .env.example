# =============================================================================
# HomeBase CRM — Environment Variables
# Copy this file to ".env" and fill in your own values:  cp .env.example .env
# Never commit your real .env — only this example belongs in version control.
# =============================================================================

# =============================================================================
# DATABASE
# Default: SQLite (local dev). Swap for your Railway PostgreSQL URL in production.
# =============================================================================
DATABASE_URL=sqlite:///app.db

# =============================================================================
# ADMIN LOGIN
# Username and password for the /admin dashboard. Change these!
# =============================================================================
ADMIN_USER=admin
ADMIN_PASS=change-me

# =============================================================================
# FLASK SECRET KEY
# Used to sign session cookies. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================
SECRET_KEY=change-me-in-production

# =============================================================================
# BUSINESS BRANDING
# Displayed in the UI header and emails. Change to your business name.
# =============================================================================
BUSINESS_NAME=HomeBase CRM

# =============================================================================
# FEATURE TOGGLES
# Set to "false" to hide a section from the UI and skip its blueprint.
# =============================================================================
FEATURE_PRODUCTS=true
FEATURE_CLIENTS=true
FEATURE_TASKS=true
FEATURE_EMAIL=true
FEATURE_ANALYTICS=true
FEATURE_BOOKINGS=true

# =============================================================================
# JACKIE AI ASSISTANT
# CHAT_PROVIDER: "openai" for direct OpenAI, "openrouter" for OpenRouter
# OPENAI_API_KEY: Required if CHAT_PROVIDER=openai
# OPENROUTER_API_KEY: Required if CHAT_PROVIDER=openrouter (also used for content)
#
# VOICE MODE: Jackie can talk back and forth live (click the orb). Voice uses
# the OpenAI Realtime API, so it needs a REAL OpenAI key (an OpenRouter
# sk-or-... key works for text chat but NOT for voice). ~$0.06/min; the
# session auto-disconnects after 2 min of silence. Model/voice are optional.
# =============================================================================
OPENAI_API_KEY=
CHAT_PROVIDER=openai
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=shimmer

# =============================================================================
# AI / CONTENT APIs
# OPENROUTER  — AI text generation (Claude, GPT-4, etc.) — powers the email generator & Jackie
# FIRECRAWL   — Web scraping & crawling
# KIE_AI      — GPT Image-2 image generation (via kie.ai)
# ZERNIO      — Social scheduling / publishing (formerly GetLate.dev)
# =============================================================================
OPENROUTER_API_KEY=
FIRECRAWL_API_KEY=
KIE_AI_API_KEY=
ZERNIO_API_KEY=
ZERNIO_PROFILE_ID=

# =============================================================================
# CRM INTEGRATIONS
# STRIPE_CHECKOUT_URL  — Direct link to your Stripe payment page
# LEAD_MAGNET_URL      — URL of your opt-in / lead magnet page
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_CHECKOUT_URL=
LEAD_MAGNET_URL=

# =============================================================================
# EMAIL (Resend)
# Resend is used for transactional emails (receipts, follow-ups, etc.)
# Sign up at https://resend.com — free tier is 3,000 emails/month.
# =============================================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# =============================================================================
# GMAIL OAUTH (send generated follow-up emails directly from the app)
# One-time setup in Google Cloud Console (https://console.cloud.google.com):
#   1. New project -> enable the "Gmail API".
#   2. OAuth consent screen: External. While in "Testing", add your Gmail as a
#      test user.
#   3. Credentials -> Create OAuth client ID -> "Web application".
#   4. Authorized redirect URI (exactly):
#        http://localhost:8000/admin/gmail/callback
#   5. Paste the client ID + secret below, restart, then click "Connect Gmail"
#      on the AI Follow-Up Email page.
# Scope used is gmail.send only (least privilege).
# =============================================================================
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# =============================================================================
# STORAGE (Cloudflare R2)
# R2 is used for uploaded files (logos, profile photos) and exports.
# R2_PUBLIC_URL is the public domain attached to your R2 bucket.
# =============================================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# =============================================================================
# UMAMI ANALYTICS (free at umami.is)
# Sign up at umami.is, create a website, copy the Website ID.
# =============================================================================
UMAMI_WEBSITE_ID=
UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
